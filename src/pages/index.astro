---
const steps = [
	{
		title: "1. Konzultáció és tervezés",
		text: "Megismerjük a céget és a célkitűzéseidet, majd megtervezzük az oldal szerkezetét és a fő üzeneteket.",
	},
	{
		title: "2. AI-asszisztált fejlesztés",
		text: "A tartalmat és a kódot AI-támogatott folyamatunkkal építjük fel, így gyorsan készül el a gyors, letisztult weboldal.",
	},
	{
		title: "3. Tesztelés és élesítés",
		text: "Ellenőrizzük a sebességet és a SEO-beállításokat, majd közzétesszük az oldalt Cloudflare-en.",
	},
];
---

<html lang="hu">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Eurocon Web Design – Gyors, SEO-barát weboldalak</title>
		<meta
			name="description"
			content="Az Eurocon Web Design gyors, SEO-barát weboldalakat épít AI-asszisztált folyamattal. Kérj ajánlatot egy modern, jól teljesítő weboldalra."
		/>
	</head>
	<body>
		<main>
			<!-- Hero -->
			<section>
				<h1>Gyors, SEO-barát weboldalak az Eurocon Web Designtól</h1>
				<p>
					AI-asszisztált folyamatunkkal modern, gyorsan betöltődő és keresőbarát
					weboldalakat építünk – kevesebb idő alatt, kiszámítható minőségben.
				</p>
				<p>
					<a href="#kapcsolat">Kérj ajánlatot</a>
				</p>
			</section>

			<!-- Probléma -->
			<section>
				<h2>A probléma</h2>
				<p>
					Sok kisvállalkozás weboldala lassú, nehezen található meg a Google-ben,
					és a frissítése túl sok időt vesz igénybe. Ez ügyfeleket és bevételt jelent
					kiesésben.
				</p>
			</section>

			<!-- Megoldás -->
			<section>
				<h2>A megoldásunk</h2>
				<p>
					Statikusan renderelt, valódi HTML-re épülő weboldalakat készítünk, amelyek
					villámgyorsan töltődnek be és könnyen optimalizálhatók a keresőkre. Az
					AI-asszisztált pipeline-unk felgyorsítja a fejlesztést, így gyorsabban
					juthatsz kész, jól teljesítő oldalhoz.
				</p>
			</section>

			<!-- Folyamat -->
			<section>
				<h2>Hogyan dolgozunk – 3 lépésben</h2>
				<ol>
					{
						steps.map((step) => (
							<li>
								<h3>{step.title}</h3>
								<p>{step.text}</p>
							</li>
						))
					}
				</ol>
			</section>

			<!-- Kapcsolat CTA -->
			<section id="kapcsolat">
				<h2>Kezdjük el a projektedet</h2>
				<p>
					Szeretnél gyors, SEO-barát weboldalt? Írj nekünk, és segítünk
					megtervezni a következő lépéseket.
				</p>
				<p>
					<a href="mailto:hello@euroconwebdesign.hu">hello@euroconwebdesign.hu</a>
				</p>
			</section>
		</main>

		<!-- Chatbox widget -->
		<div id="chatbox">
			<button id="chat-toggle" type="button" aria-expanded="false" aria-controls="chat-panel">
				Chat
			</button>
			<div id="chat-panel" role="dialog" aria-label="Chat" hidden>
				<div id="chat-header">Eurocon Web Design</div>
				<div id="chat-messages">
					<p class="chat-bot">Szia! Miben segíthetünk?</p>
				</div>
				<form id="chat-form">
					<input
						id="chat-input"
						type="text"
						placeholder="Írd ide az üzeneted…"
						autocomplete="off"
						aria-label="Üzenet"
					/>
					<button type="submit">Küldés</button>
				</form>
			</div>
		</div>

		<style>
			main {
				text-align: center;
			}
			main ol {
				list-style-position: inside;
				padding-left: 0;
			}
			#chatbox {
				position: fixed;
				right: 1rem;
				bottom: 1rem;
				z-index: 1000;
				font-family: system-ui, sans-serif;
			}
			#chat-toggle {
				padding: 0.6rem 1.1rem;
				border: none;
				border-radius: 999px;
				background: #1a56db;
				color: #fff;
				cursor: pointer;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
			}
			#chat-panel {
				width: 280px;
				margin-top: 0.5rem;
				border: 1px solid #ddd;
				border-radius: 8px;
				background: #fff;
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
				overflow: hidden;
			}
			#chat-header {
				padding: 0.6rem 0.8rem;
				background: #1a56db;
				color: #fff;
				font-weight: 600;
			}
			#chat-messages {
				padding: 0.8rem;
				max-height: 200px;
				overflow-y: auto;
			}
			#chat-messages p {
				margin: 0 0 0.5rem;
				padding: 0.4rem 0.6rem;
				border-radius: 6px;
				background: #f1f1f1;
			}
			#chat-messages p.chat-user {
				background: #dbeafe;
				text-align: right;
			}
			#chat-form {
				display: flex;
				border-top: 1px solid #eee;
			}
			#chat-input {
				flex: 1;
				border: none;
				padding: 0.6rem;
			}
			#chat-form button {
				border: none;
				background: #1a56db;
				color: #fff;
				padding: 0 0.9rem;
				cursor: pointer;
			}
		</style>

		<script>
			const toggle = document.getElementById("chat-toggle");
			const panel = document.getElementById("chat-panel");
			const form = document.getElementById("chat-form");
			const input = document.getElementById("chat-input") as HTMLInputElement;
			const messages = document.getElementById("chat-messages");

			toggle?.addEventListener("click", () => {
				const isOpen = !panel?.hasAttribute("hidden");
				if (isOpen) {
					panel?.setAttribute("hidden", "");
				} else {
					panel?.removeAttribute("hidden");
				}
				toggle.setAttribute("aria-expanded", String(!isOpen));
				if (!isOpen) input?.focus();
			});

			form?.addEventListener("submit", (e) => {
				e.preventDefault();
				const text = input.value.trim();
				if (!text) return;
				const userMsg = document.createElement("p");
				userMsg.className = "chat-user";
				userMsg.textContent = text;
				messages?.appendChild(userMsg);
				input.value = "";

				const botMsg = document.createElement("p");
				botMsg.className = "chat-bot";
				botMsg.textContent = "Köszönjük az üzenetet! Hamarosan válaszolunk.";
				messages?.appendChild(botMsg);
				if (messages) messages.scrollTop = messages.scrollHeight;
			});
		</script>
	</body>
</html>
